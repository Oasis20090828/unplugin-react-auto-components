{
  "name": "unplugin-react-auto-components",
  "version": "0.2.0",
  "description": "On-demand React components auto-import for Vite / Webpack / Rollup",
  "keywords": [
    "react",
    "components",
    "auto-import",
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "on-demand"
  ],
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    },
    "./resolvers": {
      "types": "./dist/resolvers.d.ts",
      "import": "./dist/resolvers.mjs",
      "require": "./dist/resolvers.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@rollup/pluginutils": "^5.1.0",
    "estree-walker": "^3.0.3",
    "fast-glob": "^3.3.2",
    "local-pkg": "^1.2.1",
    "magic-string": "^0.30.7",
    "unplugin": "^1.10.0"
  },
  "devDependencies": {
    "@babel/types": "^7.24.0",
    "@types/estree": "^1.0.5",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
