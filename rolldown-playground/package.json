{
  "name": "rolldown-playground",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i ./index.css -o ./tailwind.css && node build.mjs",
    "dev": "tailwindcss -i ./index.css -o ./tailwind.css --watch & node build.mjs --watch"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@tailwindcss/cli": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rolldown": "latest",
    "tailwindcss": "^4.0.0",
    "unplugin-react-auto-components": "workspace:*"
  },
  "dependencies": {
    "antd": "6.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  }
}
